generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Tournament {
  id          String   @id @default(uuid())
  name        String
  sourceUrl   String   @unique
  source      String
  location    String
  city        String
  state       String
  startDate   String
  endDate     String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skillLevels   TournamentSkillLevel[]
  registrations UserTournamentRegistration[]

  @@index([city, state, startDate])
  @@index([startDate])
}

model TournamentSkillLevel {
  id           String     @id @default(uuid())
  skillLevel   String
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, skillLevel])
  @@index([skillLevel])
}

model ScrapeLog {
  id              String   @id @default(uuid())
  source          String
  startTime       DateTime @default(now())
  endTime         DateTime?
  tournamentsFound Int     @default(0)
  errors          String?
  status          String   @default("running")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id          String   @id @default(uuid())
  googleId    String   @unique
  email       String   @unique
  name        String
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  registrations UserTournamentRegistration[]
}

model UserTournamentRegistration {
  id           String   @id @default(uuid())
  userId       String
  tournamentId String
  status       String   @default("PENDING") // PENDING | CONFIRMED
  clickedAt    DateTime @default(now())
  confirmedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([userId, tournamentId])
  @@index([userId])
  @@index([tournamentId])
  @@index([userId, status])
}
