{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:server": "npm run build && npm run start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "scrape": "curl -s -X POST http://localhost:3001/api/scrape/trigger",
    "scrape:maincourt": "curl -s -X POST http://localhost:3001/api/scrape/trigger -H \"Content-Type: application/json\" -d '{\"source\": \"maincourt.com\"}'",
    "scrape:pickleballtournaments": "curl -s -X POST http://localhost:3001/api/scrape/trigger -H \"Content-Type: application/json\" -d '{\"source\": \"pickleballtournaments.com\"}'"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/adapter-libsql": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "puppeteer": "^24.37.5"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "eslint": "^8.57.0",
    "prisma": "^7.4.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
