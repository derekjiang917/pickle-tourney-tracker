generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Tournament {
  id          String   @id @default(uuid())
  name        String
  sourceUrl   String   @unique
  source      String
  location    String
  city        String
  state       String
  startDate   DateTime
  endDate     DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skillLevels TournamentSkillLevel[]

  @@index([city, state, startDate])
  @@index([startDate])
}

model TournamentSkillLevel {
  id           String     @id @default(uuid())
  skillLevel   String
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, skillLevel])
  @@index([skillLevel])
}

model ScrapeLog {
  id               String    @id @default(uuid())
  source           String
  startTime        DateTime  @default(now())
  endTime          DateTime?
  tournamentsFound Int       @default(0)
  errors           String?
  status           String    @default("running")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())
}
