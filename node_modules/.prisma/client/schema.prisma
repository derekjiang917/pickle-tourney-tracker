generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Tournament {
  id          String   @id @default(uuid())
  name        String
  sourceUrl   String
  source      String
  location    String
  city        String
  state       String
  startDate   DateTime
  endDate     DateTime
  skillLevels String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sourceUrl])
}

model ScrapeLog {
  id               String    @id @default(uuid())
  source           String
  startTime        DateTime  @default(now())
  endTime          DateTime?
  tournamentsFound Int       @default(0)
  errors           String?
  status           String    @default("running")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
